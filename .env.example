# ─── My-CRM environment variables ───────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit your actual .env to source control.

# ─── Core ────────────────────────────────────────────────────────────────────

# Node environment (development | production | test)
NODE_ENV=development

# HTTP port (Render / Railway set this automatically)
PORT=3001

# JWT signing secret — generate a strong random value for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-only-secret-change-in-production

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# When set, PostgreSQL is used as the primary data store.
# When absent, the server falls back to JSON file storage (development default).
#
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Render:  set DATABASE_URL to your Render PostgreSQL internal connection string
# Railway: automatically injected when you add a PostgreSQL service
# Local:   postgres://postgres:password@localhost:5432/mycrm
DATABASE_URL=

# ─── Data directory (JSON file fallback) ─────────────────────────────────────
# Override the directory used for JSON file storage.
# Leave blank to use the default (~/Desktop/CRM-Data on macOS/Linux).
# Render already sets this to /var/data via render.yaml.
DATA_DIR_OVERRIDE=

# ─── Admin accounts ──────────────────────────────────────────────────────────
# Password for the built-in nmora_exclusive@outlook.com admin account.
# Set this in production to something strong. Default is "changeme123".
NMORA_PASSWORD=changeme123

# ─── VAPID (Web Push Notifications) ─────────────────────────────────────────
# Generate once with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── Twilio (SMS Notifications) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── SMTP (Email Notifications) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── DocuSign (optional) ─────────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
